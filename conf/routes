# Routes
# This file defines all application routes (Higher priority routes first)
# https://www.playframework.com/documentation/latest/ScalaRouting
# ~~~~

# An example controller showing a sample home page
GET     /                             controllers.HomeController.index()

# ===== REST API (SPA フロント向け / JSON) =====
GET     /api/todos                    controllers.api.TodoApiController.list()
POST    /api/todos                    controllers.api.TodoApiController.create()
GET     /api/todos/:id                controllers.api.TodoApiController.get(id: Long)
PUT     /api/todos/:id                controllers.api.TodoApiController.update(id: Long)
DELETE  /api/todos/:id                controllers.api.TodoApiController.delete(id: Long)
GET     /api/statuses                 controllers.api.TodoApiController.statuses()
GET     /api/categories               controllers.api.CategoryApiController.list()
POST    /api/categories               controllers.api.CategoryApiController.create()
GET     /api/categories/:id           controllers.api.CategoryApiController.get(id: Long)
PUT     /api/categories/:id           controllers.api.CategoryApiController.update(id: Long)
DELETE  /api/categories/:id           controllers.api.CategoryApiController.delete(id: Long)
GET     /api/colors                   controllers.api.CategoryApiController.colors()

# Todo一覧表示
GET     /todos                        controllers.TodoController.list()

# Todo新規追加 (フォーム表示 / 登録処理)
GET     /todos/new                    controllers.TodoController.register()
POST    /todos                        controllers.TodoController.create()

# Todo更新 (フォーム表示 / 更新処理)
GET     /todos/:id/edit               controllers.TodoController.edit(id: Long)
POST    /todos/:id                    controllers.TodoController.update(id: Long)

# Todo削除
POST    /todos/:id/delete             controllers.TodoController.delete(id: Long)

# Category一覧表示
GET     /categories                   controllers.CategoryController.list()

# Category新規追加 (フォーム表示 / 登録処理)
GET     /categories/new               controllers.CategoryController.register()
POST    /categories                   controllers.CategoryController.create()

# Category更新 (フォーム表示 / 更新処理)
GET     /categories/:id/edit          controllers.CategoryController.edit(id: Long)
POST    /categories/:id               controllers.CategoryController.update(id: Long)

# Category削除 (関連 Todo も削除)
POST    /categories/:id/delete        controllers.CategoryController.delete(id: Long)

# Map static resources from the /public folder to the /assets URL path
GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)
