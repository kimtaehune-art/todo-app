# Routes
# This file defines all application routes (Higher priority routes first)
# https://www.playframework.com/documentation/latest/ScalaRouting
# ~~~~

# An example controller showing a sample home page
GET     /                             controllers.HomeController.index()

# Todo一覧表示
GET     /todos                        controllers.TodoController.list()

# Todo新規追加 (フォーム表示 / 登録処理)
GET     /todos/new                    controllers.TodoController.register()
POST    /todos                        controllers.TodoController.create()

# Todo更新 (フォーム表示 / 更新処理)
GET     /todos/:id/edit               controllers.TodoController.edit(id: Long)
POST    /todos/:id                    controllers.TodoController.update(id: Long)

# Todo削除
POST    /todos/:id/delete             controllers.TodoController.delete(id: Long)

# Category一覧表示
GET     /categories                   controllers.CategoryController.list()

# Category新規追加 (フォーム表示 / 登録処理)
GET     /categories/new               controllers.CategoryController.register()
POST    /categories                   controllers.CategoryController.create()

# Map static resources from the /public folder to the /assets URL path
GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)
